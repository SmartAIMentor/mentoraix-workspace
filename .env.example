# ============================================================
# Mentoraix Workspace 统一环境变量
# 复制为 .env 后填入实际值：cp .env.example .env
# ============================================================

# === 通用 API Keys ===
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === mentoraixs (Next.js :3000) ===
# mentoraixs → publish-service 后端
MENTORAIX_API_BASE_URL=http://localhost:58888
MENTORAIX_PUBLISH_API_BASE_URL=http://localhost:58889
MENTORAIX_CREATOR_ID=kris
MENTORAIX_CANDIDATE_CREATOR_ID=kris
APP_NAME=mentoraixs

# AI Providers（mentoraixs AI 路由使用）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ORBITAI_API_KEY=
ORBITAI_BASE_URL=https://aiapi.orbitai.global/v1
ORBITAI_MODEL=gpt-5.4

# mentoraixs → ClawCore 智能体
CLAWCORE_BASE_URL=http://localhost:8001
CLAWCORE_API_KEY=

# 认证与数据库（Mentoraixs 新增）
AUTH_SECRET=
DATABASE_URL=
DATABASE_PROVIDER=

# 发布相关
PUBLISH_DRY_RUN=true
POST_BRIDGE_API_KEY=
POST_BRIDGE_BASE_URL=https://api.post-bridge.com
POST_BRIDGE_VIDEO_COVER_TIMESTAMP_MS=3000
POST_BRIDGE_TIKTOK_DRAFT=false
POST_BRIDGE_TIKTOK_IS_AIGC=false
POST_BRIDGE_INSTAGRAM_IS_TRIAL_REEL=false

# === publish-service Backend (FastAPI :58888) ===
# Social media publishing via Bundle Social API
BUNDLE_SOCIAL_API_KEY=
BUNDLE_SOCIAL_BASE_URL=https://api.bundle.social
BUNDLE_SOCIAL_PORTAL_REDIRECT_URL=http://localhost:3000/social/callback
APP_ENV=development
DATA_DIR=backend/data
UPLOAD_DIR=backend/data/uploads

# === RecSys (Flask :8000) ===
# 使用上方的 GEMINI_API_KEY

# === ClawCore (FastAPI :8001) ===
# 端口由启动脚本传入 uvicorn --port，无需在此配置
MOONSHOT_API_KEY=

# === 数据采集 ===
TIKHUB_API_KEY=
TIKHUB_API_BASE_URL=

# === 可选代理 ===
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=
